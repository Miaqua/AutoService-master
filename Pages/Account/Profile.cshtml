@page
@model RazorCrudAppAuth.Pages.Account.ProfileModel
@{
    ViewData["Title"] = "Личный кабинет";
}

<div class="profile-container">
    <div class="profile-header">
        <div class="header-content">
            <div class="user-welcome">
                <h1>Добро пожаловать!</h1>
                <p>Здесь вы можете управлять своими данными и заявками</p>
            </div>
            <div class="stats-cards">
                <div class="stat-card primary">
                    <div class="stat-icon">📋</div>
                    <div class="stat-info">
                        <span class="stat-number">@Model.UserRepairRequests.Count</span>
                        <span class="stat-label">Всего заявок</span>
                    </div>
                </div>
                <div class="stat-card success">
                    <div class="stat-icon">✅</div>
                    <div class="stat-info">
                        <span class="stat-number">@Model.GetCompletedRequests()</span>
                        <span class="stat-label">Выполнено</span>
                    </div>
                </div>
                <div class="stat-card warning">
                    <div class="stat-icon">⭐</div>
                    <div class="stat-info">
                        <span class="stat-number">@Model.UserReviews.Count</span>
                        <span class="stat-label">Мои отзывы</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Main Content -->
    <div class="profile-main">
        <div class="profile-layout">
            <!-- Left Sidebar - Quick Actions -->
            <div class="sidebar">
                <div class="sidebar-section">
                    <h3>Быстрые действия</h3>
                    <div class="quick-actions">
                        <a asp-page="/RepairRequests/Index" class="action-btn primary">
                            <span class="action-icon">➕</span>
                            Новая заявка
                        </a>
                        <a asp-page="/Reviews/Create" class="action-btn secondary">
                            <span class="action-icon">💬</span>
                            Оставить отзыв
                        </a>
                    </div>
                </div>

                <div class="sidebar-section">
                    <h3>Статусы заявок</h3>
                    <div class="status-overview">
                        <div class="status-item">
                            <span class="status-dot new"></span>
                            <span>Новые</span>
                            <span class="status-count">@Model.UserRepairRequests.Count(r => r.Status?.ToLower() == "новая")</span>
                        </div>
                        <div class="status-item">
                            <span class="status-dot in-progress"></span>
                            <span>В работе</span>
                            <span class="status-count">@Model.UserRepairRequests.Count(r => r.Status?.ToLower() == "в работе")</span>
                        </div>
                        <div class="status-item">
                            <span class="status-dot completed"></span>
                            <span>Завершено</span>
                            <span class="status-count">@Model.UserRepairRequests.Count(r => r.Status?.ToLower() == "завершено")</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Main Content Area -->
            <div class="main-content">
                <!-- Personal Info Card -->
                <div class="content-card">
                    <div class="card-header">
                        <h2>👤 Личная информация</h2>
                        <button type="button" class="btn-edit" onclick="toggleEdit()" id="editButton">
                            <span class="edit-icon">✏️</span>
                            Редактировать
                        </button>
                    </div>

                    <form id="profileForm" method="post" class="profile-form">
                        <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

                        <div class="form-grid">
                            <div class="form-group">
                                <label asp-for="Input.FullName">Полное имя</label>
                                <div class="input-wrapper">
                                    <span class="input-icon">👤</span>
                                    <input asp-for="Input.FullName" class="form-input" readonly />
                                </div>
                                <span asp-validation-for="Input.FullName" class="validation-message"></span>
                            </div>

                            <div class="form-group">
                                <label asp-for="Input.Email">Email</label>
                                <div class="input-wrapper">
                                    <span class="input-icon">📧</span>
                                    <input asp-for="Input.Email" class="form-input" readonly />
                                </div>
                                <span asp-validation-for="Input.Email" class="validation-message"></span>
                            </div>

                            <div class="form-group">
                                <label asp-for="Input.PhoneNumber">Номер телефона</label>
                                <div class="input-wrapper">
                                    <span class="input-icon">📱</span>
                                    <input asp-for="Input.PhoneNumber" class="form-input" readonly />
                                </div>
                                <span asp-validation-for="Input.PhoneNumber" class="validation-message"></span>
                            </div>
                        </div>

                        <div class="form-actions" style="display: none;">
                            <button type="submit" class="btn-save">
                                <span class="btn-icon">💾</span>
                                Сохранить изменения
                            </button>
                            <button type="button" class="btn-cancel" onclick="toggleEdit()">
                                <span class="btn-icon">❌</span>
                                Отмена
                            </button>
                        </div>
                    </form>
                </div>

                <!-- Repair Requests -->
                <div class="content-card">
                    <div class="card-header">
                        <h2>📋 Мои заявки на ремонт</h2>
                        <span class="card-badge">@Model.UserRepairRequests.Count</span>
                    </div>

                    @if (Model.UserRepairRequests.Any())
                    {
                        <div class="requests-list">
                            @foreach (var request in Model.UserRepairRequests)
                            {
                                <div class="request-item">
                                    <div class="request-main">
                                        <div class="request-title">
                                            <h4>@request.Service?.Title</h4>
                                            <span class="request-date">@request.PreferredDate.ToString("dd.MM.yyyy")</span>
                                        </div>
                                        <div class="request-details">
                                            <div class="detail-item">
                                                <span class="detail-label">Клиент:</span>
                                                <span class="detail-value">@request.CustomerName</span>
                                            </div>
                                            <div class="detail-item">
                                                <span class="detail-label">Телефон:</span>
                                                <span class="detail-value">@request.PhoneNumber</span>
                                            </div>
                                            @if (request.Service != null)
                                            {
                                                <div class="detail-item">
                                                    <span class="detail-label">Стоимость:</span>
                                                    <span class="detail-value price">@request.Service.Price.ToString("C")</span>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                    <div class="request-status">
                                        <span class="status-badge @GetStatusClass(request.Status)">@request.Status</span>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="empty-state">
                            <div class="empty-icon">📋</div>
                            <h3>Заявок пока нет</h3>
                            <p>Создайте свою первую заявку на ремонт</p>
                            <a asp-page="/RepairRequests/Index" class="btn-primary">
                                <span class="btn-icon">➕</span>
                                Создать заявку
                            </a>
                        </div>
                    }
                </div>

                <!-- Reviews -->
                <div class="content-card">
                    <div class="card-header">
                        <h2>⭐ Мои отзывы</h2>
                        <span class="card-badge">@Model.UserReviews.Count</span>
                    </div>

                    @if (Model.UserReviews.Any())
                    {
                        <div class="reviews-grid">
                            @foreach (var review in Model.UserReviews)
                            {
                                <div class="review-card @(review.IsApproved ? "approved" : "pending")">
                                    <div class="review-header">
                                        <div class="rating-stars">
                                            @for (int i = 0; i < 5; i++)
                                            {
                                                <span class="star @(i < review.Rating ? "active" : "")">★</span>
                                            }
                                        </div>
                                        <div class="review-meta">
                                            <span class="review-date">@review.CreatedAt.ToString("dd.MM.yyyy")</span>
                                            <span class="review-badge @(review.IsApproved ? "approved" : "pending")">
                                                @(review.IsApproved ? "✅ Одобрен" : "⏳ На модерации")
                                            </span>
                                        </div>
                                    </div>
                                    <p class="review-text">@review.Text</p>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="empty-state">
                            <div class="empty-icon">⭐</div>
                            <h3>Отзывов пока нет</h3>
                            <p>Поделитесь своим мнением о наших услугах</p>
                            <a asp-page="/Reviews/Create" class="btn-primary">
                                <span class="btn-icon">💬</span>
                                Оставить отзыв
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    :root {
        --primary: #4361ee;
        --primary-dark: #3a56d4;
        --secondary: #7209b7;
        --success: #4cc9f0;
        --warning: #f72585;
        --danger: #e63946;
        --dark: #2b2d42;
        --light: #f8f9fa;
        --gray: #6c757d;
        --gray-light: #adb5bd;
        --border: #e9ecef;
        --shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
        --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
    }

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    .profile-container {
        min-height: 100vh;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    }

    .profile-header {
        background: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(10px);
        padding: 2rem 0;
        border-bottom: 1px solid rgba(255, 255, 255, 0.2);
    }

    .header-content {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 2rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 2rem;
    }

    .user-welcome h1 {
        color: white;
        font-size: 2.5rem;
        font-weight: 700;
        margin-bottom: 0.5rem;
    }

    .user-welcome p {
        color: rgba(255, 255, 255, 0.8);
        font-size: 1.1rem;
    }

    .stats-cards {
        display: flex;
        gap: 1rem;
    }

    .stat-card {
        background: rgba(255, 255, 255, 0.2);
        backdrop-filter: blur(10px);
        border-radius: 15px;
        padding: 1.5rem;
        display: flex;
        align-items: center;
        gap: 1rem;
        min-width: 180px;
        border: 1px solid rgba(255, 255, 255, 0.3);
    }

    .stat-icon {
        font-size: 2rem;
    }

    .stat-info {
        display: flex;
        flex-direction: column;
    }

    .stat-number {
        font-size: 1.8rem;
        font-weight: 700;
        color: white;
        line-height: 1;
    }

    .stat-label {
        font-size: 0.9rem;
        color: rgba(255, 255, 255, 0.8);
        margin-top: 0.25rem;
    }

    .profile-main {
        padding: 2rem;
    }

    .profile-layout {
        max-width: 1200px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: 300px 1fr;
        gap: 2rem;
    }

    .sidebar {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .sidebar-section {
        background: white;
        border-radius: 15px;
        padding: 1.5rem;
        box-shadow: var(--shadow);
    }

        .sidebar-section h3 {
            color: var(--dark);
            margin-bottom: 1rem;
            font-size: 1.1rem;
            font-weight: 600;
        }

    .quick-actions {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .action-btn {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 1rem;
        border-radius: 10px;
        text-decoration: none;
        font-weight: 500;
        transition: all 0.3s ease;
        border: none;
        cursor: pointer;
    }

        .action-btn.primary {
            background: var(--primary);
            color: white;
        }

        .action-btn.secondary {
            background: var(--light);
            color: var(--dark);
            border: 1px solid var(--border);
        }

        .action-btn:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow-lg);
        }

    .status-overview {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .status-item {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.75rem;
        border-radius: 8px;
        background: var(--light);
    }

    .status-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
    }

        .status-dot.new {
            background: var(--primary);
        }

        .status-dot.in-progress {
            background: var(--warning);
        }

        .status-dot.completed {
            background: var(--success);
        }

    .status-count {
        margin-left: auto;
        font-weight: 600;
        color: var(--dark);
    }

    .main-content {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .content-card {
        background: white;
        border-radius: 15px;
        padding: 2rem;
        box-shadow: var(--shadow);
    }

    .card-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.5rem;
        padding-bottom: 1rem;
        border-bottom: 2px solid var(--border);
    }

        .card-header h2 {
            color: var(--dark);
            font-size: 1.5rem;
            font-weight: 600;
        }

    .card-badge {
        background: var(--primary);
        color: white;
        padding: 0.25rem 0.75rem;
        border-radius: 20px;
        font-size: 0.9rem;
        font-weight: 600;
    }

    .btn-edit, .btn-save, .btn-cancel {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.75rem 1.5rem;
        border-radius: 10px;
        border: none;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.3s ease;
    }

        .btn-edit.editing {
            background: #e63946 !important;
            color: white !important;
        }

    .btn-save {
        background: var(--success);
        color: white;
    }

    .btn-cancel {
        background: var(--light);
        color: var(--gray);
        border: 1px solid var(--border);
    }

    .form-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1.5rem;
    }

    .form-group {
        display: flex;
        flex-direction: column;
    }

        .form-group label {
            font-weight: 600;
            margin-bottom: 0.5rem;
            color: var(--dark);
        }

    .input-wrapper {
        position: relative;
        display: flex;
        align-items: center;
    }

    .input-icon {
        position: absolute;
        left: 1rem;
        z-index: 2;
    }

    .form-input {
        width: 100%;
        padding: 1rem 1rem 1rem 3rem;
        border: 2px solid var(--border);
        border-radius: 10px;
        font-size: 1rem;
        transition: all 0.3s ease;
        background: var(--light);
    }

        .form-input:focus {
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(67, 97, 238, 0.1);
            outline: none;
            background: white;
        }

        .form-input:read-only {
            background: #f8f9fa !important;
            cursor: not-allowed !important;
            border-color: #e9ecef !important;
        }

        .form-input:not(:read-only) {
            background: white !important;
            cursor: text !important;
            border-color: #4361ee !important;
        }

    .form-actions {
        display: flex;
        gap: 1rem;
        margin-top: 1.5rem;
    }

    .requests-list, .reviews-grid {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .request-item {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        padding: 1.5rem;
        background: var(--light);
        border-radius: 10px;
        border-left: 4px solid var(--primary);
        transition: all 0.3s ease;
    }

        .request-item:hover {
            transform: translateX(5px);
            box-shadow: var(--shadow);
        }

    .request-main {
        flex: 1;
    }

    .request-title {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1rem;
    }

        .request-title h4 {
            color: var(--dark);
            font-size: 1.1rem;
            font-weight: 600;
        }

    .request-date {
        color: var(--gray);
        font-size: 0.9rem;
    }

    .request-details {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 0.75rem;
    }

    .detail-item {
        display: flex;
        gap: 0.5rem;
    }

    .detail-label {
        font-weight: 600;
        color: var(--gray);
    }

    .detail-value {
        color: var(--dark);
    }

    .price {
        font-weight: 600;
        color: var(--success);
    }

    .status-badge {
        padding: 0.5rem 1rem;
        border-radius: 20px;
        font-size: 0.8rem;
        font-weight: 600;
        text-transform: uppercase;
    }

    .status-new {
        background: #e3f2fd;
        color: #1976d2;
    }

    .status-pending {
        background: #fff3e0;
        color: #f57c00;
    }

    .status-in-progress {
        background: #e8f5e8;
        color: #388e3c;
    }

    .status-completed {
        background: #e8f5e8;
        color: #388e3c;
    }

    .status-cancelled {
        background: #ffebee;
        color: #d32f2f;
    }

    .review-card {
        padding: 1.5rem;
        background: var(--light);
        border-radius: 10px;
        border-left: 4px solid var(--warning);
    }

        .review-card.approved {
            border-left-color: var(--success);
        }

        .review-card.pending {
            border-left-color: var(--warning);
        }

    .review-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 1rem;
    }

    .rating-stars {
        display: flex;
        gap: 0.25rem;
    }

    .star {
        color: #ddd;
        font-size: 1.2rem;
    }

        .star.active {
            color: #ffc107;
        }

    .review-meta {
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: 0.5rem;
    }

    .review-date {
        color: var(--gray);
        font-size: 0.9rem;
    }

    .review-badge {
        padding: 0.25rem 0.75rem;
        border-radius: 12px;
        font-size: 0.8rem;
        font-weight: 600;
    }

        .review-badge.approved {
            background: #e8f5e8;
            color: #388e3c;
        }

        .review-badge.pending {
            background: #fff3e0;
            color: #f57c00;
        }

    .review-text {
        color: var(--dark);
        line-height: 1.6;
    }

    .empty-state {
        text-align: center;
        padding: 3rem 2rem;
        color: var(--gray);
    }

    .empty-icon {
        font-size: 4rem;
        margin-bottom: 1rem;
        opacity: 0.5;
    }

    .empty-state h3 {
        color: var(--dark);
        margin-bottom: 0.5rem;
        font-size: 1.5rem;
    }

    .empty-state p {
        margin-bottom: 2rem;
        font-size: 1.1rem;
    }

    .btn-primary {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 1rem 2rem;
        background: var(--primary);
        color: white;
        text-decoration: none;
        border-radius: 10px;
        font-weight: 500;
        transition: all 0.3s ease;
    }

        .btn-primary:hover {
            background: var(--primary-dark);
            transform: translateY(-2px);
            box-shadow: var(--shadow-lg);
        }

    .validation-summary {
        background: #ffebee;
        color: #d32f2f;
        padding: 1rem;
        border-radius: 8px;
        margin-bottom: 1.5rem;
    }

    .validation-message {
        color: #d32f2f;
        font-size: 0.875rem;
        margin-top: 0.25rem;
    }

    @@media (max-width: 1024px) {
        .profile-layout {
            grid-template-columns: 1fr;
        }

        .header-content {
            flex-direction: column;
            text-align: center;
        }

        .stats-cards {
            justify-content: center;
        }
    }

    @@media (max-width: 768px) {
        .profile-main {
            padding: 1rem;
        }

        .stats-cards {
            flex-direction: column;
            width: 100%;
        }

        .stat-card {
            min-width: auto;
        }

        .card-header {
            flex-direction: column;
            gap: 1rem;
            align-items: flex-start;
        }

        .request-item {
            flex-direction: column;
            gap: 1rem;
        }

        .request-title {
            flex-direction: column;
            align-items: flex-start;
            gap: 0.5rem;
        }

        .review-header {
            flex-direction: column;
            gap: 1rem;
        }

        .review-meta {
            align-items: flex-start;
        }

        .form-actions {
            flex-direction: column;
        }
    }
</style>

<script>
    function toggleEdit() {
        const form = document.getElementById('profileForm');
        const inputs = form.querySelectorAll('input.form-input');
        const actions = form.querySelector('.form-actions');
        const editButton = document.querySelector('.btn-edit');

        const isEditing = inputs[0].readOnly; 

        inputs.forEach(input => {
            input.readOnly = !isEditing; 
            if (!isEditing) {
                input.style.background = '#f8f9fa';
                input.style.cursor = 'not-allowed';
            } else {
                input.style.background = 'white';
                input.style.cursor = 'text';
            }
        });

        if (isEditing) {
            actions.style.display = 'flex';
            editButton.innerHTML = '<span class="edit-icon">❌</span> Отменить';
            editButton.style.background = '#e63946';
            editButton.style.color = 'white';
        } else {
            actions.style.display = 'none';
            editButton.innerHTML = '<span class="edit-icon">✏️</span> Редактировать';
            editButton.style.background = '';
            editButton.style.color = '';
        }
    }

    document.addEventListener('DOMContentLoaded', function() {
        const cancelButton = document.querySelector('.btn-cancel');
        if (cancelButton) {
            cancelButton.addEventListener('click', function() {
                location.reload();
            });
        }

        // Анимации карточек
        const cards = document.querySelectorAll('.content-card');
        cards.forEach((card, index) => {
            card.style.opacity = '0';
            card.style.transform = 'translateY(20px)';

            setTimeout(() => {
                card.style.transition = 'all 0.5s ease';
                card.style.opacity = '1';
                card.style.transform = 'translateY(0)';
            }, index * 100);
        });
    });
</script>

@functions {
    private string GetStatusClass(string status)
    {
        return status?.ToLower() switch
        {
            "новая" => "status-new",
            "в ожидании" => "status-pending",
            "в работе" => "status-in-progress",
            "завершено" => "status-completed",
            "отменено" => "status-cancelled",
            _ => "status-new"
        };
    }
}