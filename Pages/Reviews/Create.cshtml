@page
@model RazorCrudAppAuth.Pages.Reviews.CreateModel

@{
    ViewData["Title"] = "Создание отзыва";
}

<div class="page-container">
    <div class="page-header">
        <h1 class="page-title">📝 Создать отзыв</h1>
        <p class="page-subtitle">Оставьте свой отзыв о сервисе</p>
    </div>

    <div class="form-card mx-auto" style="max-width: 600px;">
        <form method="post" class="styled-form">
            <div asp-validation-summary="ModelOnly" class="validation-summary mb-3"></div>

            <div class="form-group">
                <label asp-for="Review.Text">Текст отзыва</label>
                <input asp-for="Review.Text" class="input-text" />
                <span asp-validation-for="Review.Text" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Review.Rating">Оценка (1–5)</label>
                <input asp-for="Review.Rating" type="number" class="input-text" />
                <span asp-validation-for="Review.Rating" class="text-danger"></span>
            </div>

            <input type="hidden" asp-for="Review.UserId" />

            <div class="form-actions mt-4">
                <button type="submit" class="btn-primary w-100">Отправить отзыв</button>
            </div>
        </form>

        <div class="text-center mt-3">
            <a asp-page="Index" class="btn-outline">↩ Назад к списку</a>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
