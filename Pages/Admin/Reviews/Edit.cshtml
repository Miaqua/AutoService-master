@page
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin")]
@model RazorCrudAppAuth.Pages.Admin.Reviews.EditModel

@{
    ViewData["Title"] = "Редактирование отзыва";
}

<div class="page-container">
    <div class="page-header">
        <h1 class="page-title">✏️ Редактировать отзыв</h1>
        <p class="page-subtitle">Измените содержимое и статус отзыва</p>
    </div>

    @if (!User.IsInRole("Admin"))
    {
        <div class="empty-state">
            <div class="empty-icon">🚫</div>
            <h3>Доступ запрещён</h3>
            <p>Эта страница доступна только администраторам.</p>
            <a asp-page="/Index" class="btn-outline">🏠 На главную</a>
        </div>
    }
    else
    {
        <div class="form-card">
            <form method="post" class="styled-form">
                <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

                <input type="hidden" asp-for="Review.Id" />

                <div class="form-group">
                    <label asp-for="Review.Text">Текст отзыва</label>
                    <textarea asp-for="Review.Text" class="input-textarea" rows="4"></textarea>
                    <span asp-validation-for="Review.Text" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Review.Rating">Рейтинг</label>
                    <input asp-for="Review.Rating" type="number" min="1" max="5" class="input-text" />
                    <span asp-validation-for="Review.Rating" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Review.CreatedAt">Дата создания</label>
                    <input asp-for="Review.CreatedAt" type="datetime-local" class="input-text" />
                    <span asp-validation-for="Review.CreatedAt" class="text-danger"></span>
                </div>

                <div class="form-group form-check">
                    <input class="form-check-input" asp-for="Review.IsApproved" id="IsApproved" />
                    <label class="form-check-label" for="IsApproved">Одобрен</label>
                </div>

                <div class="form-group">
                    <label asp-for="Review.UserId">Пользователь</label>
                    <select asp-for="Review.UserId" class="input-select" asp-items="ViewBag.UserId"></select>
                    <span asp-validation-for="Review.UserId" class="text-danger"></span>
                </div>

                <div class="form-actions">
                    <button type="submit" name="action" value="save" class="btn-primary">💾 Сохранить</button>
                    <button type="submit" name="action" value="approve" class="btn-success">✅ Подтвердить</button>
                    <button type="submit" name="action" value="reject" class="btn-danger">❌ Отклонить</button>
                    <a asp-page="./Index" class="btn-outline">↩ Назад</a>
                </div>
            </form>
        </div>
    }
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
