@page
@model RazorCrudAppAuth.Pages.Admin.Contacts.IndexModel

@{
    ViewData["Title"] = "Список контактов";
}

<div class="page-container">
    <div class="page-header">
        <h1 class="page-title">📋 Контакты</h1>
        <div class="mt-3 mb-3">
            <a asp-page="Create" class="btn-primary">Добавить контакт</a>
        </div>
    </div>

    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>Адрес</th>
                <th>Телефон</th>
                <th>Email</th>
                <th>Время работы</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Contact)
            {
                <tr>
                    <td>@item.Address</td>
                    <td>@item.Phone</td>
                    <td>@item.Email</td>
                    <td>@item.WorkingHours</td>
                    <td>
                        <a asp-page="./Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary me-1">Редактировать</a>
                        <a asp-page="./Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Подробнее</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
