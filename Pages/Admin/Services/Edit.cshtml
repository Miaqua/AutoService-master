@page
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin")]
@model RazorCrudAppAuth.Pages.Admin.Services.EditModel

@{
    ViewData["Title"] = "Редактирование услуги";
}

<div class="page-container">
    <div class="page-header">
        <h1 class="page-title">✏️ Редактировать услугу</h1>
        <p class="page-subtitle">Измените данные текущей услуги</p>
    </div>

    @if (!User.IsInRole("Admin"))
    {
        <div class="empty-state">
            <div class="empty-icon">🚫</div>
            <h3>Доступ запрещён</h3>
            <p>Эта страница доступна только администраторам.</p>
            <a asp-page="/Index" class="btn-outline">🏠 На главную</a>
        </div>
    }
    else
    {
        <div class="form-card">
            <form method="post" class="styled-form">
                <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

                <input type="hidden" asp-for="Service.Id" />

                <div class="form-group">
                    <label asp-for="Service.Title">Название услуги</label>
                    <input asp-for="Service.Title" class="input-text" />
                    <span asp-validation-for="Service.Title" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Service.Description">Описание</label>
                    <input asp-for="Service.Description" class="input-text" />
                    <span asp-validation-for="Service.Description" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Service.Price">Цена</label>
                    <input asp-for="Service.Price" type="number" step="0.01" class="input-text" />
                    <span asp-validation-for="Service.Price" class="text-danger"></span>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn-primary">💾 Сохранить</button>
                    <a asp-page="./Index" class="btn-outline">↩ Назад</a>
                </div>
            </form>
        </div>
    }
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
