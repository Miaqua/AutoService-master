@page
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin")]
@model RazorCrudAppAuth.Pages.Admin.Services.CreateModel

@{
    ViewData["Title"] = "Создание услуги";
}

<div class="page-container">
    <div class="page-header">
        <h1 class="page-title">🧾 Добавление услуги</h1>
        <p class="page-subtitle">Создайте новую услугу для отображения на сайте</p>
    </div>

    <div class="form-card">
        <form method="post" class="form-styled">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group">
                <label asp-for="Service.Title" class="form-label">Название услуги</label>
                <input asp-for="Service.Title" class="form-control" placeholder="Введите название услуги..." />
                <span asp-validation-for="Service.Title" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Service.Description" class="form-label">Описание</label>
                <textarea asp-for="Service.Description" class="form-control" rows="4" placeholder="Опишите услугу..."></textarea>
                <span asp-validation-for="Service.Description" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Service.Price" class="form-label">Стоимость (₽)</label>
                <input asp-for="Service.Price" type="number" min="0" step="0.01" class="form-control" placeholder="Введите цену" />
                <span asp-validation-for="Service.Price" class="text-danger"></span>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-primary">💾 Создать</button>
                <a asp-page="Index" class="btn-outline">↩️ Назад к списку</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
