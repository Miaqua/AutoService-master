@page
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin")]
@model RazorCrudAppAuth.Pages.Admin.RepairRequests.EditModel

@{
    ViewData["Title"] = "Редактирование запроса на ремонт";
}

<div class="page-container">
    <div class="page-header">
        <h1 class="page-title">✏️ Редактировать запрос на ремонт</h1>
        <p class="page-subtitle">Измените данные текущего запроса</p>
    </div>

    @if (!User.IsInRole("Admin"))
    {
        <div class="empty-state">
            <div class="empty-icon">🚫</div>
            <h3>Доступ запрещён</h3>
            <p>Эта страница доступна только администраторам.</p>
            <a asp-page="/Index" class="btn-outline">🏠 На главную</a>
        </div>
    }
    else
    {
        <div class="form-card">
            <form method="post" class="styled-form">
                <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

                <input type="hidden" asp-for="RepairRequest.Id" />

                <input type="hidden" asp-for="RepairRequest.UserId" />
                <!-- User поле не нужно в форме, достаточно UserId -->

                <div class="form-group">
                    <label asp-for="RepairRequest.CustomerName">Имя клиента</label>
                    <input asp-for="RepairRequest.CustomerName" class="input-text" />
                    <span asp-validation-for="RepairRequest.CustomerName" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="RepairRequest.PhoneNumber">Телефон</label>
                    <input asp-for="RepairRequest.PhoneNumber" class="input-text" />
                    <span asp-validation-for="RepairRequest.PhoneNumber" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="RepairRequest.PreferredDate">Предпочтительная дата</label>
                    <input asp-for="RepairRequest.PreferredDate" type="date" class="input-text" />
                    <span asp-validation-for="RepairRequest.PreferredDate" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="RepairRequest.Status">Статус</label>
                    <select asp-for="RepairRequest.Status" class="input-select" asp-items="ViewBag.StatusList"></select>
                    <span asp-validation-for="RepairRequest.Status" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="RepairRequest.ServiceId">Услуга</label>
                    <select asp-for="RepairRequest.ServiceId" class="input-select" asp-items="ViewBag.ServiceId"></select>
                    <span asp-validation-for="RepairRequest.ServiceId" class="text-danger"></span>
                </div>


                <div class="form-actions">
                    <button type="submit" class="btn-primary">💾 Сохранить</button>
                    <a asp-page="./Index" class="btn-outline">↩ Назад</a>
                </div>
            </form>

        </div>
    }
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
